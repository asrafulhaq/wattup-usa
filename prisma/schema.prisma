generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  COLLABORATOR
}

// Permission enum is used for type-safe RBAC in application code.
// Role → Permission mapping is defined in lib/permissions.ts.
enum Permission {
  // Post management
  CREATE_POST
  EDIT_ANY_POST
  EDIT_OWN_POST
  DELETE_ANY_POST
  DELETE_OWN_POST
  PUBLISH_POST

  // Site management
  MANAGE_SITE_SETTINGS
  MANAGE_SOCIAL_LINKS

  // User management
  VIEW_USERS
  INVITE_USERS
  EDIT_USERS
  CHANGE_USER_ROLE
  DELETE_USERS
  BAN_USERS
}

// ─── Better Auth Core Models ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  bio           String?   @default("")
  imagePublicId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role          Role      @default(COLLABORATOR)

  // Better Auth admin plugin fields
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?

  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?

  // admin plugin
  impersonatedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Profile {
  id        String   @id @default(uuid())
  name      String   @default("")
  bio       String   @default("")
  image     Json?
  about     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([id])
}

model SocialLink {
  id        String   @id @default(uuid())
  userId    String
  name      String   @default("")
  url       String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
}

model Posts {
  id         String    @id @default(uuid())
  title      String
  slug       String?   @unique @default("")
  content    String?   @default("")
  image      String?   @default("")
  imageAlt  String?   @default("")
  author     String?   @default("")
  authorUrl  String?   @default("")
  featured   Boolean   @default(false)
  featuredImage Json?
  status     String    @default("Draft")
  publishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
  @@index([id])
  @@index([slug])
  @@index([status])
  @@index([publishedAt])
}

model SiteSettings {
  id                     String   @id @default("singleton")

  // Google Tracking
  googleAnalyticsId      String?
  googleTagManagerId     String?
  googleSiteVerification String?

  // Meta / Facebook
  metaPixelId            String?

  // Custom Script Injection (raw HTML)
  headScripts            String?
  bodyStartScripts       String?
  bodyEndScripts         String?

  // AEO / Organization Schema
  orgName                String?
  orgDescription         String?
  orgUrl                 String?
  orgPhone               String?
  orgEmail               String?
  orgAddress             String?
  orgLogoUrl             String?
  orgTwitter             String?
  orgLinkedin            String?
  orgFacebook            String?
  orgInstagram           String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("site_settings")
}
